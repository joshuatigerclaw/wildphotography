# WildPhotography .env.example

# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Site
SITE_BASE_URL=https://wildphotography.com
MEDIA_BASE_URL=https://media.wildphotography.com

# Visionati
VISIONATI_API_KEY=
VISIONATI_BASE_URL=https://api.visionati.com
VISIONATI_DESCRIBE_ENDPOINT=/v1/analyze
VISIONATI_TIMEOUT_MS=45000

# Backends / features
VISIONATI_DESCRIPTION_BACKENDS=openai,gemini,claude
VISIONATI_FEATURES=descriptions
VISIONATI_ROLE=wildphotography_editorial
VISIONATI_LANGUAGE=en

# One-time run controls
VISIONATI_RUN_LIMIT_PER_CATEGORY=15
VISIONATI_MAX_RETRIES=1
VISIONATI_DESCRIPTION_VERSION=visionati-wildphotography-v1

# Optional app settings
NODE_ENV=production
